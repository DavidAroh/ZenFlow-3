{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a ZenFlow user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth ID." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's full name." },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role in the system." }
      },
      "required": ["uid", "email"]
    },
    "Task": {
      "title": "Task",
      "description": "A productivity task with stress tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "stress": { "type": "string", "enum": ["Low Stress", "Med Stress", "High Stress"] },
        "status": { "type": "string", "enum": ["backlog", "todo", "in-progress", "done"] },
        "dueDate": { "type": "string" },
        "assignee": { "type": "string" },
        "authorUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status", "authorUid"]
    },
    "WellnessEntry": {
      "title": "Wellness Entry",
      "description": "A daily mood and energy check-in.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "mood": { "type": "integer", "description": "1-5 scale" },
        "energy": { "type": "string", "enum": ["low", "medium", "high"] },
        "reflection": { "type": "string" },
        "authorUid": { "type": "string" }
      },
      "required": ["mood", "energy", "authorUid"]
    },
    "WorkLog": {
      "title": "Work Log",
      "description": "A record of a work session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "duration": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "overworked"] },
        "authorUid": { "type": "string" }
      },
      "required": ["date", "startTime", "status", "authorUid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Global tasks (or user-specific if filtered)."
    },
    "/wellness_entries/{entryId}": {
      "schema": "WellnessEntry",
      "description": "Personal wellness logs."
    },
    "/work_logs/{logId}": {
      "schema": "WorkLog",
      "description": "Personal work session logs."
    }
  }
}
